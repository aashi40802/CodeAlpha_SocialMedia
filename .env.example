# Copy this file to ".env" and fill in your own values.

# Port the server runs on
PORT=5000

# MongoDB connection string.
# Option A (easiest): free MongoDB Atlas cluster -> https://www.mongodb.com/atlas
#   Looks like: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vibe
# Option B: local MongoDB installed on your machine
#   mongodb://127.0.0.1:27017/vibe
MONGO_URI=mongodb://127.0.0.1:27017/vibe

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long a login token stays valid
JWT_EXPIRES_IN=7d

# The URL your React frontend runs on (for CORS)
CLIENT_URL=http://localhost:5173
